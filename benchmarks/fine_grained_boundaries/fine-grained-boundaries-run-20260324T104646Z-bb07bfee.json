  "rules": [
    {
      "rule_name": "phrase_saver_when_compression_misses_and_saver_can_restore",
      "conditions": [
        "missing_under_compression_count >= 1",
        "top_phrase_saver_restored >= 1"
      ],
      "preferred_mode": "phrase_saver_per_byte_mode",
      "evidence_count": 0,
      "notes": "Use phrase-saver rescue when compression drops required phrases and local saver evidence exists."
    },
    {
      "rule_name": "hybrid_when_compression_misses_and_phrase_saver_signal_is_absent",
      "conditions": [
        "missing_under_compression_count >= 1",
        "top_phrase_saver_restored == 0 OR phrase_saver insufficient"
      ],
      "preferred_mode": "hybrid_mode",
      "evidence_count": 5,
      "notes": "Use hybrid when compression misses required phrases and local middle-strength rescue is absent or insufficient."
    },
    {
      "rule_name": "fragment_when_fragment_signal_is_real_and_small_gap_remains",
      "conditions": [
        "missing_under_compression_count >= 1",
        "top_fragment_restored >= 1",
        "top_fragment_ppc > 0"
      ],
      "preferred_mode": "phrase_fragment_per_byte_mode",
      "evidence_count": 1,
      "notes": "Use fragment rescue only when fragment evidence is real."
    },
    {
      "rule_name": "compression_when_nothing_important_is_missing",
      "conditions": [
        "missing_under_compression_count == 0"
      ],
      "preferred_mode": "compression_mode",
      "evidence_count": 3,
      "notes": "Keep compression when it already preserves required signal."
    },
    {
      "rule_name": "do_not_force_compression_when_required_phrases_are_missing",
      "conditions": [
        "learned_choice == compression_mode",
        "missing_under_compression_count >= 1"
      ],
      "preferred_mode": "threshold_gated_adaptive_mode",
      "evidence_count": 2,
      "notes": "Coarse learned boundaries over-compress when missing phrases are not explicitly checked."
    },
    {
      "rule_name": "phrase_saver_is_primary_middle_state",
      "conditions": [
        "saver_equals_threshold on many scenarios"
      ],
      "preferred_mode": "phrase_saver_per_byte_mode",
      "evidence_count": 12,
      "notes": "Phrase-saver is the key middle-strength rescue mode."
    }
